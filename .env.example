# Copy to .env and fill in real values. DO NOT commit the real .env.
# In Dokploy these go in the app's Environment tab (not in git).

# --- Server ---
NODE_ENV=development
PORT=5006
API_VERSION=v1
SERVICE_NAME=vdrive-admin-be
PROD_URL=
COOKIE_DOMAIN=

# --- Database (Postgres) ---
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_NAME_TEST=
PGSSLMODE=
PGCHANNELBINDING=

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth / JWT ---
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Internal service comms ---
INTERNAL_SECRET=
INTERNAL_SERVICE_API_KEY=
INTERNAL_SERVICE_SECRET=
USER_BACKEND_WEBHOOK_URL=
USER_DRIVER_API_URL=
AWS_SERVICE_URL=

# --- Email / SMTP ---
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=
SMTP_USER=

# --- Google Cloud Vision (OCR) ---
# Path INSIDE the container to the service-account JSON key.
# In Dokploy: add a File Mount (Advanced -> Volumes -> File Mount) with this
# mount path and paste the key JSON as its content, then set the var below.
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-key.json
